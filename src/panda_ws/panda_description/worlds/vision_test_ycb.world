<sdf version='1.9'>
  <!-- Misma mesa y entorno que vision_test.world, sin piezas geométricas de color
       (para dataset YCB: mesa vacía salvo lo que spawnea el generador). -->
  <world name='vision_test_ycb_world'>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic'/>

    <!-- DEBUG estabilidad: SceneBroadcaster dispara warnings de serialización
         justo antes del segfault en ros2_control. Lo desactivamos para aislar. -->

    <!-- 100 Hz: alineado con controller_manager (panda_controllers.yaml) para
         evitar avisos y posibles carreras con gz_ros2_control. -->
    <physics type='ode'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- Iluminación suave para dataset: menos caras negras por sombras duras / contraste -->
    <scene>
      <ambient>0.78 0.78 0.78 1</ambient>
      <background>0.75 0.78 0.82 1</background>
      <shadows>false</shadows>
    </scene>

    <light name='sun' type='directional'>
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>0.95</intensity>
      <direction>-0.35 0.25 -0.9</direction>
      <diffuse>0.92 0.92 0.92 1</diffuse>
      <specular>0.35 0.35 0.35 1</specular>
      <attenuation>
        <range>1000</range>
        <linear>0.01</linear>
        <constant>0.9</constant>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <light name='fill' type='directional'>
      <pose>0 0 8 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>0.55</intensity>
      <direction>0.45 -0.35 -0.85</direction>
      <diffuse>0.88 0.88 0.95 1</diffuse>
      <specular>0.15 0.15 0.18 1</specular>
    </light>

    <model name='ground_plane'>
      <static>true</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name='vision_test_table'>
      <static>true</static>
      <link name='table_top'>
        <pose>0.60 0.0 0.24 0 0 0</pose>
        <collision name='table_collision'>
          <geometry>
            <box>
              <size>0.72 0.48 0.04</size>
            </box>
          </geometry>

        </collision>
        <visual name='table_visual'>
          <geometry>
            <box>
              <size>0.72 0.48 0.04</size>
            </box>
          </geometry>
          <material>
            <ambient>0.45 0.28 0.15 1</ambient>
            <diffuse>0.45 0.28 0.15 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='table_leg_front_left'>
      <static>true</static>
      <link name='link'>
        <pose>0.34 0.18 0.11 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.18 0.08 1</ambient>
            <diffuse>0.32 0.18 0.08 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='table_leg_front_right'>
      <static>true</static>
      <link name='link'>
        <pose>0.86 0.18 0.11 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.18 0.08 1</ambient>
            <diffuse>0.32 0.18 0.08 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='table_leg_back_left'>
      <static>true</static>
      <link name='link'>
        <pose>0.34 -0.18 0.11 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.18 0.08 1</ambient>
            <diffuse>0.32 0.18 0.08 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='table_leg_back_right'>
      <static>true</static>
      <link name='link'>
        <pose>0.86 -0.18 0.11 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.04 0.04 0.22</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.18 0.08 1</ambient>
            <diffuse>0.32 0.18 0.08 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Bandeja demo 2x2 compacta: interior ~0.37 x 0.37 m, paredes ~0.16 m (top z≈0.17) -->
    <model name='deposit_box'>
      <static>true</static>
      <pose>-0.46 0 0 0 0 0</pose>

      <link name='bottom'>
        <pose>0 0 0.005 0 0 0</pose>
        <collision name='collision'>
          <geometry><box><size>0.37 0.37 0.01</size></box></geometry>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.37 0.37 0.01</size></box></geometry>
          <material>
            <ambient>0.35 0.25 0.15 1</ambient>
            <diffuse>0.35 0.25 0.15 1</diffuse>
          </material>
        </visual>
      </link>

      <link name='wall_front'>
        <pose>0.190 0 0.090 0 0 0</pose>
        <collision name='collision'>
          <geometry><box><size>0.01 0.37 0.16</size></box></geometry>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.01 0.37 0.16</size></box></geometry>
          <material>
            <ambient>0.40 0.30 0.18 1</ambient>
            <diffuse>0.40 0.30 0.18 1</diffuse>
          </material>
        </visual>
      </link>

      <link name='wall_back'>
        <pose>-0.190 0 0.090 0 0 0</pose>
        <collision name='collision'>
          <geometry><box><size>0.01 0.37 0.16</size></box></geometry>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.01 0.37 0.16</size></box></geometry>
          <material>
            <ambient>0.40 0.30 0.18 1</ambient>
            <diffuse>0.40 0.30 0.18 1</diffuse>
          </material>
        </visual>
      </link>

      <link name='wall_left'>
        <pose>0 0.190 0.090 0 0 0</pose>
        <collision name='collision'>
          <geometry><box><size>0.37 0.01 0.16</size></box></geometry>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.37 0.01 0.16</size></box></geometry>
          <material>
            <ambient>0.40 0.30 0.18 1</ambient>
            <diffuse>0.40 0.30 0.18 1</diffuse>
          </material>
        </visual>
      </link>

      <link name='wall_right'>
        <pose>0 -0.190 0.090 0 0 0</pose>
        <collision name='collision'>
          <geometry><box><size>0.37 0.01 0.16</size></box></geometry>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.37 0.01 0.16</size></box></geometry>
          <material>
            <ambient>0.40 0.30 0.18 1</ambient>
            <diffuse>0.40 0.30 0.18 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
  </world>
</sdf>
